import request from 'supertest';
import { jest } from '@jest/globals';
import app from '../../src/app.js';
import { createAuthCookie, cleanupDb } from '../utils/testHelpers.js';
import Album from '../../src/models/Album.js';
import Image from '../../src/models/Image.js';

describe('Album Routes', () => {
  let authCookie;

  beforeEach(async () => {
    authCookie = await createAuthCookie();
    await Album.deleteMany({});
    await Image.deleteMany({});
  });

  afterEach(async () => {
    await cleanupDb();
  });

  describe('GET /albums', () => {
    it('returns empty array when no albums exist', async () => {
      const res = await request(app).get('/albums').expect(200);

      expect(res.body.success).toBe(true);
      expect(res.body.data).toEqual([]);
    });

    it('returns albums with image counts', async () => {
      const album = new Album({ name: 'Test Album' });
      await album.save();

      const res = await request(app).get('/albums').expect(200);

      expect(res.body.success).toBe(true);
      expect(res.body.data).toHaveLength(1);
      expect(res.body.data[0].name).toBe('Test Album');
    });
  });

  describe('POST /albums', () => {
    it('creates an album when authenticated as admin', async () => {
      const res = await request(app)
        .post('/albums')
        .set('Cookie', authCookie)
        .send({ name: 'New Album', description: 'A new album' })
        .expect(201);

      expect(res.body.success).toBe(true);
      expect(res.body.data.name).toBe('New Album');
    });

    it('returns 409 for duplicate album names', async () => {
      const album = new Album({ name: 'Duplicate' });
      await album.save();

      const res = await request(app)
        .post('/albums')
        .set('Cookie', authCookie)
        .send({ name: 'Duplicate' })
        .expect(409);

      expect(res.body.success).toBe(false);
      expect(res.body.error).toBe('Album name already exists');
    });

    it('returns 401 when not authenticated', async () => {
      await request(app).post('/albums').send({ name: 'Test' }).expect(401);
    });
  });

  describe('GET /albums/:id/images', () => {
    it('returns paginated images for an album', async () => {
      const album = new Album({ name: 'Gallery' });
      await album.save();

      const image = new Image({
        filename: 'test.jpg',
        path: '/uploads/test.jpg',
        user_ip: '127.0.0.1',
        album: album._id,
      });
      await image.save();

      const res = await request(app).get(`/albums/${album._id}/images`).expect(200);

      expect(res.body.success).toBe(true);
      expect(res.body.data.data).toHaveLength(1);
    });

    it('returns 400 for invalid album ID', async () => {
      const res = await request(app).get('/albums/invalid-id/images').expect(400);

      expect(res.body.success).toBe(false);
    });
  });

  describe('PATCH /albums/:id', () => {
    it('updates album cover image', async () => {
      const album = new Album({ name: 'Gallery' });
      await album.save();

      const image = new Image({
        filename: 'test.jpg',
        path: '/uploads/test.jpg',
        user_ip: '127.0.0.1',
        album: album._id,
      });
      await image.save();

      const res = await request(app)
        .patch(`/albums/${album._id}`)
        .set('Cookie', authCookie)
        .send({ coverImage: image._id.toString() })
        .expect(200);

      expect(res.body.success).toBe(true);
      expect(res.body.data.coverImage.toString()).toBe(image._id.toString());
    });
  });
});
